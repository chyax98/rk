{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
"strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@renderkit/shared/contracts": ["../../packages/shared/src/contracts.ts"],
      "@renderkit/shared": ["../../packages/shared/src/index.ts"],
      "@renderkit/blocks": ["../../packages/blocks/src/index.tsx"],
      "@renderkit/dsl": ["../../packages/dsl/src/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
