{
  "name": "renderkit-workspace",
  "version": "0.0.2-alpha.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @renderkit/web dev",
    "build": "pnpm --filter @renderkit/web build && pnpm --filter @renderkit/cli build",
    "renderkit": "node packages/cli/bin/renderkit.mjs",
    "push:example": "pnpm renderkit push examples/hello.html --open",
    "format": "npx @biomejs/biome format --write .",
    "biome:check": "npx @biomejs/biome check .",
    "ci:local": "pnpm biome:check",
    "test": "node --experimental-strip-types --test tests/comment-anchor.test.ts tests/store-routes.test.ts tests/html-processor.test.ts tests/wc-render.test.ts tests/cli.test.ts",

    "test:wc": "node --experimental-strip-types --test tests/wc-render.test.ts",
    "test:cli": "node --experimental-strip-types --test tests/cli.test.ts",
    "score": "node --experimental-strip-types scripts/score.ts",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@eslint/js": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "lefthook": "^2.1.6",
    "linkedom": "^0.18.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "sharp",
      "lefthook"
    ]
  }
}
