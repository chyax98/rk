{
  "name": "renderkit-workspace",
  "version": "0.0.2-alpha.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @renderkit/web dev",
    "build": "pnpm --filter @renderkit/web build && pnpm --filter @renderkit/cli build",
    "renderkit": "node --experimental-strip-types packages/cli/src/index.ts",
    "push:example": "pnpm renderkit push examples/plan.rk.md --open",
    "verify": "node --experimental-strip-types scripts/verify.ts",
    "verify:smoke": "node --experimental-strip-types scripts/verify-smoke.ts",
    "verify:sqlite": "node --experimental-strip-types scripts/verify-sqlite.ts",
    "verify:browser": "node --experimental-strip-types scripts/verify-browser.ts",
    "verify:contracts": "node --experimental-strip-types scripts/verify-contracts.ts",
    "verify:agent": "node --experimental-strip-types scripts/verify-agent.ts"
  },
  "devDependencies": {},
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "sharp"
    ]
  }
}