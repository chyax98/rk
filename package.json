{
  "name": "renderkit-workspace",
  "version": "0.0.2-alpha.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @renderkit/web dev",
    "build": "pnpm --filter @renderkit/web build && pnpm --filter @renderkit/cli build",
    "renderkit": "node packages/cli/bin/renderkit.mjs",
    "push:example": "pnpm renderkit push examples/plan.rk.md --open",
    "verify:contracts": "node --experimental-strip-types scripts/verify-contracts.ts",
    "lint": "node --experimental-strip-types node_modules/.bin/eslint 'packages/**/*.{ts,tsx}' 'apps/web/app/**/*.{ts,tsx}' --max-warnings 80",
    "format": "npx @biomejs/biome format --write .",
    "biome:check": "npx @biomejs/biome check .",
    "ci:local": "pnpm biome:check && pnpm lint && pnpm verify:contracts",
    "ci": "pnpm verify:contracts",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@eslint/js": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "lefthook": "^2.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "sharp",
      "lefthook"
    ]
  }
}
