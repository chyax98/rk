{
  "name": "renderkit-workspace",
  "version": "0.0.2-alpha.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @renderkit/web dev",
    "build": "pnpm --filter @renderkit/web build && pnpm --filter @renderkit/cli build",
    "renderkit": "node packages/cli/bin/renderkit.mjs",

    "push:example": "pnpm renderkit push examples/plan.rk.md --open",
    "verify": "node scripts/verify.mjs",
    "verify:smoke": "node scripts/verify-smoke.mjs",
    "verify:sqlite": "node scripts/verify-sqlite.mjs",
    "verify:browser": "node scripts/verify-browser.mjs",
    "verify:contracts": "node scripts/verify-contracts.mjs"
  },
  "devDependencies": {}
}
