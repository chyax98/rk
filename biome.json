{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "apps/**/*.ts",
      "apps/**/*.tsx",
      "apps/**/*.css",
      "apps/**/*.json",
      "packages/**/*.ts",
      "packages/**/*.tsx",
      "packages/**/*.css",
      "packages/**/*.json",
      "tests/**/*.ts",
      "*.json",
      "!**/node_modules",
      "!**/.next",
      "!**/dist",
      "!**/.data",
      "!**/.pwcli",
      "!apps/web/public/rk/components.js",
      "!apps/web/public/rk/components.css",
      "!apps/web/public/rk/app-style-backup.css",
      "!apps/web/next-env.d.ts",
      "!**/*.tsbuildinfo",
      "!packages/blocks/src/index.d.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedImports": "warn",
        "noUnusedVariables": "warn"
      },
      "suspicious": {
        "noConsole": "warn",
        "noAssignInExpressions": "warn",
        "noArrayIndexKey": "warn",
        "noImplicitAnyLet": "warn",
        "useIterableCallbackReturn": "warn",
        "noExplicitAny": "warn"
      },
      "security": {
        "noDangerouslySetInnerHtml": "warn"
      },
      "style": {
        "noNonNullAssertion": "warn",
        "noDescendingSpecificity": "off"
      },
      "a11y": {
        "useButtonType": "warn",
        "noStaticElementInteractions": "warn",
        "useKeyWithClickEvents": "warn",
        "useAriaPropsSupportedByRole": "warn",
        "noAriaHiddenOnFocusable": "warn",
        "noRedundantRoles": "warn",
        "useAnchorContent": "warn",
        "useSemanticElements": "warn"
      },
      "complexity": {
        "useLiteralKeys": "warn",
        "useOptionalChain": "warn",
        "noImportantStyles": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  }
}
